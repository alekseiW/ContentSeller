# GuideHub Backend
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# JWT Auth
JWT_SECRET=guidehub-dev-secret-change-this-in-production

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/guidehub?schema=public"

# AI Providers (add keys for providers you want to use)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROK_API_KEY=

# AI Provider Priority (fallback order)
AI_TEXT_PROVIDER=openai
AI_IMAGE_PROVIDER=openai

# YooKassa
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Optional: if empty, backend returns buyer to /guide/:username/:slug with orderId
YOOKASSA_RETURN_URL=

# Prodamus (alternative)
PRODAMUS_API_KEY=
PRODAMUS_SHOP_ID=
